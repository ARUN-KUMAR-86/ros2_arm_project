<?xml version="1.0" ?>
<sdf version="1.6">

<world name="default">

  <!-- Physics -->
  <physics type="ode">
    <gravity>0 0 -9.8</gravity>
    <max_step_size>0.001</max_step_size>
    <real_time_factor>1</real_time_factor>
  </physics>

  <!-- Ground -->
  <include>
    <uri>model://ground_plane</uri>
  </include>

  <!-- Sun -->
  <include>
    <uri>model://sun</uri>
  </include>

</world>
</sdf>