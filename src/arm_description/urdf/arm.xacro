<?xml version="1.0"?>
<robot name="arm3dof">

<material name="white"><color rgba="1 1 1 1"/></material>
<material name="black"><color rgba="0 0 0 1"/></material>
<material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
<material name="dark_grey"><color rgba="0.3 0.3 0.3 1"/></material>

<!-- BASE -->
<link name="base_link">
  <visual>
    <geometry>
      <cylinder length="0.2" radius="0.2"/>
    </geometry>
    <material name="white"/>
  </visual>
</link>

<!-- SHOULDER -->
<link name="shoulder">
  <visual>
    <geometry>
      <cylinder length="0.15" radius="0.12"/>
    </geometry>
    <material name="black"/>
  </visual>
</link>

<joint name="joint1" type="revolute">
  <parent link="base_link"/>
  <child link="shoulder"/>
  <origin xyz="0 0 0.2"/>
  <axis xyz="0 0 1"/>
  <limit lower="-3.14" upper="3.14" effort="10" velocity="1"/>
</joint>

<!-- LINK1 -->
<link name="link1">
  <visual>
    <origin xyz="0.35 0 0" rpy="0 1.5707 0"/>
    <geometry>
      <cylinder length="0.7" radius="0.07"/>
    </geometry>
    <material name="white"/>
  </visual>
</link>

<joint name="joint2" type="revolute">
  <parent link="shoulder"/>
  <child link="link1"/>
  <origin xyz="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
</joint>

<!-- ELBOW -->
<link name="elbow">
  <visual>
    <geometry>
      <cylinder length="0.12" radius="0.1"/>
    </geometry>
    <material name="black"/>
  </visual>
</link>

<joint name="joint3" type="revolute">
  <parent link="link1"/>
  <child link="elbow"/>
  <origin xyz="0.7 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
</joint>

<!-- LINK2 -->
<link name="link2">
  <visual>
    <origin xyz="0.25 0 0" rpy="0 1.5707 0"/>
    <geometry>
      <cylinder length="0.5" radius="0.06"/>
    </geometry>
    <material name="white"/>
  </visual>
</link>

<joint name="joint4" type="revolute">
  <parent link="elbow"/>
  <child link="link2"/>
  <origin xyz="0 0 0"/>
  <axis xyz="0 1 0"/>
  <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
</joint>

<!-- WRIST -->
<link name="wrist">
  <visual>
    <geometry>
      <sphere radius="0.08"/>
    </geometry>
    <material name="grey"/>
  </visual>
</link>

<joint name="joint5" type="revolute">
  <parent link="link2"/>
  <child link="wrist"/>
  <origin xyz="0.5 0 0"/>
  <axis xyz="1 0 0"/>
  <limit lower="-1.57" upper="1.57" effort="10" velocity="1"/>
</joint>

<!-- GRIPPER BASE -->
<link name="gripper_base">
  <visual>
    <geometry>
      <box size="0.08 0.08 0.08"/>
    </geometry>
    <material name="dark_grey"/>
  </visual>
</link>

<joint name="gripper_mount" type="fixed">
  <parent link="wrist"/>
  <child link="gripper_base"/>
  <origin xyz="0.12 0 0"/>
</joint>

<!-- LEFT FINGER -->
<link name="left_finger">
  <visual>
    <origin xyz="0.05 0.025 0"/>
    <geometry>
      <box size="0.1 0.02 0.02"/>
    </geometry>
    <material name="black"/>
  </visual>
</link>

<joint name="left_finger_joint" type="revolute">
  <parent link="gripper_base"/>
  <child link="left_finger"/>
  <origin xyz="0 0.03 0"/>
  <axis xyz="0 0 1"/>
  <limit lower="0" upper="0.5" effort="5" velocity="1"/>
</joint>

<!-- RIGHT FINGER -->
<link name="right_finger">
  <visual>
    <origin xyz="0.05 -0.025 0"/>
    <geometry>
      <box size="0.1 0.02 0.02"/>
    </geometry>
    <material name="black"/>
  </visual>
</link>

<joint name="right_finger_joint" type="revolute">
  <parent link="gripper_base"/>
  <child link="right_finger"/>
  <origin xyz="0 -0.03 0"/>
  <axis xyz="0 0 -1"/>
  <limit lower="0" upper="0.5" effort="5" velocity="1"/>
</joint>
</robot>